# ─── Supabase ──────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NEVER expose this on the client. Server-side only (Server Actions, API routes).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App URLs ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.nirogitanman.com
NEXT_PUBLIC_PARTNER_URL=https://partner.nirogitanman.com
NEXT_PUBLIC_ADMIN_URL=https://admin.nirogitanman.com
NEXT_PUBLIC_WEB_URL=https://nirogitanman.com

# ─── Payment Gateway (e.g. Razorpay) ───────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id

# ─── Storage ───────────────────────────────────────────────
# Supabase storage bucket names (created in Supabase dashboard)
NEXT_PUBLIC_STORAGE_BUCKET_AVATARS=avatars
NEXT_PUBLIC_STORAGE_BUCKET_RECORDS=medical-records
NEXT_PUBLIC_STORAGE_BUCKET_LOGOS=partner-logos

# ─── Video Calls (e.g. Daily.co / Agora) ───────────────────
DAILY_API_KEY=your-daily-api-key
NEXT_PUBLIC_DAILY_DOMAIN=your-domain.daily.co

# ─── Notifications ─────────────────────────────────────────
# Firebase / OneSignal for push notifications
FCM_SERVER_KEY=your-fcm-server-key
